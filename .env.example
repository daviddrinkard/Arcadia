# -----------------------------------------------------------------------------
# Environment variables for Arcadia
#
# Copy this file to `.env.local` and fill in the real values for local dev.
# `.env.local` is gitignored and must never be committed.
#
# In production, set these in Vercel:
#   Project Settings → Environment Variables
# -----------------------------------------------------------------------------

# Public canonical URL of this deployment.
# Exposed to browser code — anything prefixed NEXT_PUBLIC_ is bundled into the
# client JS, so never put secrets behind this prefix.
# Local dev: http://localhost:4242
# Production: https://arcadia-sandy.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:4242

# Supabase project URL. Safe to expose to the browser.
# Grab this from Supabase: Project Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase publishable (anon) key. Safe to expose to the browser — Row Level
# Security policies on the database gate what this key can actually read/write.
# Grab this from Supabase: Project Settings → API → Publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase secret (service role) key. Server-side only — NO NEXT_PUBLIC_ prefix.
# Bypasses Row Level Security, so treat it like a database password.
# Grab this from Supabase: Project Settings → API → Secret key (reveal).
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

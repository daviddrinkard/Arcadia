# -----------------------------------------------------------------------------
# Environment variables for Arcadia
#
# Copy this file to `.env.local` and fill in the real values for local dev.
# `.env.local` is gitignored and must never be committed.
#
# In production, set these in Vercel:
#   Project Settings → Environment Variables
# -----------------------------------------------------------------------------

# Public canonical URL of this deployment.
# Exposed to browser code — anything prefixed NEXT_PUBLIC_ is bundled into the
# client JS, so never put secrets behind this prefix.
# Local dev: http://localhost:3000
# Production: https://arcadia-sandy.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB connection string. Server-side only — NO NEXT_PUBLIC_ prefix.
# Grab this from MongoDB Atlas: Database → Connect → Drivers → copy URI.
# Replace <username>, <password>, and <cluster> with your real values.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Default database name to use inside the Mongo cluster.
MONGODB_DB=arcadia
